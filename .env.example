# ─────────────────────────────────────────────────────────
# Supabase (필수)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
# ⚠️ 서비스 롤 키는 절대 클라이언트 번들에 포함하지 말 것.
# 서버 라우트(route.ts) 또는 Edge Function에서만 사용하세요.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# ─────────────────────────────────────────────────────────
# OAuth (Phase 2)
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Apple은 Supabase 대시보드에서 직접 설정

# ─────────────────────────────────────────────────────────
# 앱 설정
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Toss Puzzle
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────
# 가챠 (Phase 1) — 클라이언트에서 표시용. 실제 검증은 Edge Function.
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GACHA_DISPLAY_RATES=common:60,rare:30,epic:9,legendary:1
